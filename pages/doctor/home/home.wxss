.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  gap: 12rpx;
  padding: 8rpx 0;
}

.nav-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: var(--kj-radius-full);
  flex-shrink: 0;
}

.nav-badge--doctor {
  color: #047857;
  background: #d1fae5;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.nav-status {
  font-size: 22rpx;
  color: var(--kj-primary);
  font-weight: 600;
  flex-shrink: 0;
}

.verify-banner {
  background: linear-gradient(135deg, #fef3c7, #ffe4e6);
  border: 1rpx solid #fde68a;
  color: #92400e;
  padding: 24rpx;
  border-radius: var(--kj-radius-md);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.patient-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.patient-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
  padding-bottom: 8rpx;
}

.patient-chip {
  display: inline-block;
  vertical-align: top;
  width: 240rpx;
  padding: 24rpx 20rpx;
  margin-right: 16rpx;
  border-radius: var(--kj-radius-md);
  border: 2rpx solid #e2e8f0;
  background: #f8fafc;
  box-sizing: border-box;
}

.patient-chip--active {
  border-color: var(--kj-primary);
  background: var(--kj-bg-indigo);
}

.patient-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.3;
}

.patient-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.patient-tag {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b45309;
  background: #fef3c7;
  padding: 6rpx 14rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
}

.patient-tag--done {
  color: #047857;
  background: #d1fae5;
}

.patient-detail {
  margin-top: 20rpx;
  padding: 24rpx;
  background: var(--kj-bg-muted);
  border-radius: var(--kj-radius-md);
  border: 1rpx solid var(--kj-border);
}

.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e2e8f0;
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
  flex: 1;
  line-height: 1.4;
}

.detail-phone {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: monospace;
  flex-shrink: 0;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
}

.detail-val {
  color: #0f172a;
  font-weight: 600;
}

.detail-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.tag-done { color: #059669; }
.tag-pending { color: #e11d48; }

.rx-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.rx-item {
  background: #f8fafc;
  border-radius: var(--kj-radius-sm);
  padding: 16rpx 8rpx;
  text-align: center;
  font-size: 22rpx;
  color: #64748b;
}

.rx-val {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4338ca;
}

.slider-item {
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
}

.field-input,
.field-input-inline {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
  border-radius: var(--kj-radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  min-height: 88rpx;
  background: #f8fafc;
}

.field-input-inline {
  flex: 1;
  margin-left: 16rpx;
  margin-bottom: 0;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
}

.field-small {
  width: 140rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: var(--kj-radius-sm);
  padding: 16rpx;
  text-align: center;
  font-size: 28rpx;
  min-height: 80rpx;
  box-sizing: border-box;
}

.case-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.case-item:last-child {
  border-bottom: none;
}

.case-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
}

.case-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.verify-status {
  display: block;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #b45309;
  font-weight: 600;
  line-height: 1.5;
}

.verify-status--ok {
  color: #047857;
}

.auth-code-btn {
  margin-top: 20rpx !important;
}

.auth-code-tip {
  display: block;
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #4338ca;
  font-weight: 600;
  font-family: monospace;
  line-height: 1.5;
  word-break: break-all;
}
