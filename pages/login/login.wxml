<view class="page">
  <!-- 品牌区 -->
  <view class="brand-band">
    <view wx:if="{{step === 'login'}}" class="nav-row">
      <view class="nav-back" bindtap="onBack">← 返回</view>
      <view class="nav-badge">{{roleLabel}}</view>
    </view>
    <view class="logo">k</view>
    <text class="brand-title">「膝悦 (KneeJoy)」App</text>
  </view>

  <!-- 第一步：选身份 -->
  <block wx:if="{{step === 'role'}}">
    <text class="section-label">请选择登录入口身份：</text>

    <view
      wx:for="{{roles}}"
      wx:key="id"
      class="role-card {{selectedRole === item.id ? 'role-card--active' : ''}}"
      data-role="{{item.id}}"
      bindtap="onSelectRole"
    >
      <view class="role-icon {{item.bgClass}}">{{item.emoji}}</view>
      <view class="role-text">
        <text class="role-title">{{item.title}}</text>
        <text class="role-desc">{{item.desc}}</text>
      </view>
      <text wx:if="{{selectedRole === item.id}}" class="role-tag">已选</text>
    </view>

    <button class="btn-next" bindtap="onGoLogin">下一步，登录 / 注册 →</button>

    <view class="net-status {{serverOk ? 'net-status--ok' : 'net-status--bad'}}">
      <text wx:if="{{serverOk}}">● 后端已连接：{{apiHost}}</text>
      <text wx:else>● 后端未连接（{{apiHost}}）</text>
      <text wx:if="{{!serverOk && apiRemote}}" class="net-tip">请确认公网服务器已启动，且公众平台已配置 request 合法域名</text>
      <text wx:elif="{{!serverOk}}" class="net-tip">Mac 运行 start-production.sh；手机需与 Mac 同一 WiFi；IP 变了请改 app.js 后重新上传</text>
    </view>
  </block>

  <!-- 第二步：登录 -->
  <block wx:else>
    <view class="login-card">
      <text class="login-title">登录或注册以进入{{roleLabel}}</text>

      <view class="method-tabs">
        <view class="method-tab {{loginMethod === 'phone' ? 'method-tab--active' : ''}}" data-method="phone" bindtap="onMethodChange">手机验证码登录</view>
        <view class="method-tab {{loginMethod === 'password' ? 'method-tab--active' : ''}}" data-method="password" bindtap="onMethodChange">账号密码安全登录</view>
      </view>

      <view class="field">
        <text class="field-label">手机号码</text>
        <input class="field-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>

      <view wx:if="{{loginMethod === 'phone'}}" class="field field-sms">
        <text class="field-label">短信验证码</text>
        <view class="sms-row">
          <input class="field-input sms-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{smsCode}}" bindinput="onSmsInput" />
          <button class="sms-btn" bindtap="onSendSms" loading="{{smsSending}}" disabled="{{smsSending}}">获取验证码</button>
        </view>
        <text wx:if="{{smsHint}}" class="sms-hint">{{smsHint}}</text>
      </view>
      <view wx:else class="field">
        <text class="field-label">登录密码</text>
        <input class="field-input" password placeholder="请输入账户密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>

      <text wx:if="{{errorMsg}}" class="error">{{errorMsg}}</text>

      <button class="btn-next" bindtap="onLogin" loading="{{loading}}">立即进入对应系统端 →</button>
    </view>
  </block>

  <view class="footer">
    <text class="footer-line">提示：未注册手机号验证后将自动创建新账号</text>
    <text class="footer-line">登录即代表您同意《用户服务协议》与《隐私政策》</text>
    <text class="footer-lock">🔒 系统符合三级医院病历安全及博爱骨科医学伦理规范</text>
  </view>
</view>
