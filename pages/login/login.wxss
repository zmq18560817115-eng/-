.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 40rpx;
  box-sizing: border-box;
  background: var(--kj-bg-page);
}

.brand-band {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  padding-bottom: 36rpx;
}

.nav-row {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-back {
  font-size: 28rpx;
  color: var(--kj-text-muted);
  padding: 12rpx 0;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-badge {
  font-size: 24rpx;
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  padding: 10rpx 20rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--kj-radius-xl);
  background: linear-gradient(135deg, var(--kj-primary), var(--kj-primary-dark));
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.25);
}

.brand-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--kj-text);
  line-height: 1.3;
}

.section-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--kj-text-caption);
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.role-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--kj-bg-card);
  border: 2rpx solid var(--kj-border);
  border-radius: var(--kj-radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

.role-card--active {
  background: var(--kj-bg-indigo);
  border-color: var(--kj-primary);
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.12);
}

.role-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--kj-radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.bg-indigo { background: #e0e7ff; }
.bg-emerald { background: #d1fae5; }
.bg-pink { background: var(--kj-pink-bg); }

.role-text {
  flex: 1;
  min-width: 0;
}

.role-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--kj-text-secondary);
  line-height: 1.3;
}

.role-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--kj-text-muted);
  line-height: 1.5;
}

.role-tag {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--kj-primary-text);
  background: #e0e7ff;
  padding: 8rpx 16rpx;
  border-radius: var(--kj-radius-full);
  flex-shrink: 0;
}

.btn-next {
  margin-top: 28rpx;
  background: linear-gradient(135deg, var(--kj-primary), var(--kj-primary-dark)) !important;
  color: #fff !important;
  border-radius: var(--kj-radius-lg) !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  min-height: 96rpx !important;
  line-height: 96rpx !important;
}

.net-status {
  display: block;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--kj-radius-md);
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
}

.net-status--ok {
  color: #047857;
  background: var(--kj-success-bg);
}

.net-status--bad {
  color: var(--kj-danger);
  background: var(--kj-danger-bg);
}

.net-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--kj-danger);
}

.login-card {
  background: var(--kj-bg-card);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-xl);
  padding: 32rpx 28rpx;
  box-shadow: var(--kj-shadow);
}

.login-title {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--kj-text-muted);
  margin-bottom: 28rpx;
  line-height: 1.4;
}

.method-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: var(--kj-bg-page);
  border-radius: var(--kj-radius-md);
  padding: 6rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--kj-border);
}

.method-tab {
  text-align: center;
  padding: 20rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--kj-text-muted);
  border-radius: var(--kj-radius-sm);
  line-height: 1.3;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.method-tab--active {
  background: var(--kj-bg-card);
  color: var(--kj-primary-text);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--kj-text-muted);
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  box-sizing: border-box;
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  font-size: 30rpx;
  min-height: 88rpx;
}

.error {
  display: block;
  color: var(--kj-danger);
  font-size: 26rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.footer {
  margin-top: 36rpx;
  text-align: center;
  padding-bottom: 16rpx;
}

.footer-line,
.footer-lock {
  display: block;
  font-size: 22rpx;
  color: var(--kj-text-caption);
  line-height: 1.7;
}

.footer-lock {
  margin-top: 16rpx;
  line-height: 1.5;
}

.sms-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.sms-input {
  flex: 1;
}

.sms-btn {
  flex-shrink: 0;
  font-size: 26rpx !important;
  font-weight: 600 !important;
  background: var(--kj-bg-indigo) !important;
  color: var(--kj-primary-text) !important;
  border-radius: var(--kj-radius-md) !important;
  padding: 0 24rpx !important;
  min-height: 88rpx !important;
  line-height: 88rpx !important;
  white-space: nowrap;
}

.sms-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #047857;
  font-weight: 500;
  line-height: 1.5;
}
