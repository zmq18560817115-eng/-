<view class="page page--tab">
  <view class="card user-card">
    <text class="user-label">当前登录账号</text>
    <text class="user-name">{{userName}}</text>
    <text class="user-phone">{{userPhone}}</text>
    <text class="user-role">患者端</text>
  </view>

  <view class="card {{isLinked ? '' : 'card--dim'}}">
    <view class="section-title-row">
      <text class="section-icon">🛡️</text>
      <text class="section-title">防夹过载安全保护</text>
      <text wx:if="{{!isLinked}}" class="dim-tag">未连接设备</text>
    </view>
    <view class="force-box {{isLinked ? 'force-box--on' : 'force-box--off'}}">
      <view class="force-row">
        <text>⚠️ 恒定拉力过载保护阀</text>
        <text class="force-val">{{maxForce}} N</text>
      </view>
      <text class="force-desc">{{isLinked ? '此阀值防滑齿扣限定：当仪器反馈拉伸拉力超过阀值，系统内置气动泄压阀物理强制降压。' : '请先通过下方蓝牙或 Wi-Fi 连接理疗设备，连接成功后可调节过载保护阀值。'}}</text>
      <slider min="20" max="40" value="{{maxForce}}" activeColor="#ef4444" disabled="{{!isLinked}}" bindchange="onForceChange" />
      <view class="force-hint"><text>高保护 20N</text><text>常规上限 40N</text></view>
    </view>
  </view>

  <view class="card">
    <view class="section-head">
      <view class="section-title-row">
        <text class="section-icon">📡</text>
        <text class="section-title">硬件设备物理通信</text>
      </view>
      <text class="badge {{isLinked ? 'badge--on' : 'badge--off'}}">{{connectionLabel}}</text>
    </view>
    <view class="link-grid">
      <view class="link-card {{connection === 'bluetooth' && isLinked ? 'link-card--active' : ''}}" bindtap="onConnectBle">
        <text class="link-emoji">📶</text>
        <text class="link-title">蓝牙 BLE 绑定</text>
        <text class="link-desc">更低功耗 · 无极配对</text>
      </view>
      <view class="link-card {{connection === 'wifi' && isLinked ? 'link-card--active' : ''}}" bindtap="onConnectWifi">
        <text class="link-emoji">📡</text>
        <text class="link-title">家庭 Wi-Fi 绑定</text>
        <text class="link-desc">远程同步 · 异地数据不漏</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title-row" style="margin-bottom: 16rpx;">
      <text class="section-icon">📱</text>
      <text class="section-title">亲友绑定 QR 码</text>
    </view>
    <view class="qr-display">
      <text class="qr-token">{{bindQrToken || '加载中…'}}</text>
      <text class="qr-hint">家属端可扫描此码或输入患者手机号完成绑定</text>
    </view>
    <button class="btn-outline" bindtap="onRefreshQr">刷新绑定码</button>
  </view>

  <view class="card">
    <view class="section-title-row" style="margin-bottom: 16rpx;">
      <text class="section-icon">👨‍👩‍👧</text>
      <text class="section-title">绑定的亲友关怀账号</text>
    </view>
    <view wx:if="{{familyBindings.length === 0}}" class="empty-bindings">
      <text class="empty-title">暂无绑定的亲友账号</text>
      <text class="empty-desc">家属可在家属端通过手机号或扫码绑定您的账号，绑定后可远程关注康复进度</text>
    </view>
    <view wx:for="{{familyBindings}}" wx:key="id" class="binding-item">
      <view class="binding-left">
        <text class="binding-emoji">💗</text>
        <view>
          <text class="binding-name">{{item.family_name}} (家属端)</text>
          <text class="binding-status">已绑定状态关注中</text>
        </view>
      </view>
      <text class="binding-phone">{{item.family_phone}}</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">↩ 安全退出当前账户</button>
  <text class="logout-tip">退出后可重新选择患者 / 医生 / 家属身份登录</text>
</view>
