<view class="page page--tab">
  <view class="filter-row">
    <view
      wx:for="{{filters}}"
      wx:key="id"
      class="filter-tab {{filter === item.id ? 'filter-tab--active' : ''}}"
      data-filter="{{item.id}}"
      bindtap="onFilterChange"
    >{{item.label}}</view>
  </view>

  <view wx:if="{{loading}}" class="empty-box">正在加载消息…</view>
  <view wx:elif="{{displayList.length === 0}}" class="empty-box">
    暂无{{filterLabel}}消息
  </view>

  <view
    wx:for="{{displayList}}"
    wx:key="id"
    class="msg-card msg-card--{{item.category}} {{!item.read ? 'msg-card--unread' : ''}}"
    data-id="{{item.id}}"
    bindtap="onTapMessage"
  >
    <view class="msg-icon">{{item.category === 'doctor' ? '🩺' : '💗'}}</view>
    <view class="msg-body">
      <view class="msg-head">
        <text class="msg-title">{{item.title}}</text>
        <text wx:if="{{!item.read}}" class="unread-tag">未读</text>
      </view>
      <text wx:if="{{item.action_by}}" class="msg-from">{{item.action_by}}</text>
      <text class="msg-text">{{item.message}}</text>
      <text class="msg-time">{{item.timeText}}</text>
      <button
        wx:if="{{item.prescription_id && item.prescription_status !== 'accepted'}}"
        class="accept-btn"
        catchtap="onAcceptRx"
        data-rx-id="{{item.prescription_id}}"
        data-msg-id="{{item.id}}"
      >接受处方并载入设备</button>
    </view>
  </view>
</view>
