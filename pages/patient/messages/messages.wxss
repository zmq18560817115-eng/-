.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.empty-box {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--kj-text-caption);
  font-size: 28rpx;
  background: var(--kj-bg-card);
  border-radius: var(--kj-radius-lg);
  border: 1rpx dashed var(--kj-border);
  line-height: 1.6;
}

.msg-card {
  display: flex;
  gap: 20rpx;
  padding: 28rpx;
  background: var(--kj-bg-card);
  border-radius: var(--kj-radius-lg);
  margin-bottom: 16rpx;
  border: 1rpx solid var(--kj-border);
  box-shadow: var(--kj-shadow);
}

.msg-card--doctor {
  border-left: 6rpx solid var(--kj-primary);
}

.msg-card--family {
  border-left: 6rpx solid #ec4899;
}

.msg-card--unread {
  background: #fafbff;
  box-shadow: 0 4rpx 20rpx rgba(99, 102, 241, 0.1);
}

.msg-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--kj-radius-lg);
  background: var(--kj-bg-indigo);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.msg-card--family .msg-icon {
  background: var(--kj-pink-bg);
}

.msg-body {
  flex: 1;
  min-width: 0;
}

.msg-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.msg-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--kj-text);
  line-height: 1.4;
  flex: 1;
}

.unread-tag {
  font-size: 20rpx;
  background: var(--kj-danger);
  color: #fff;
  padding: 6rpx 12rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
  flex-shrink: 0;
}

.msg-from {
  display: block;
  font-size: 24rpx;
  color: var(--kj-text-muted);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.msg-text {
  display: block;
  font-size: 26rpx;
  color: var(--kj-text-muted);
  line-height: 1.6;
}

.msg-time {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--kj-text-caption);
}

.accept-btn {
  margin-top: 20rpx !important;
  min-height: 80rpx !important;
  line-height: 80rpx !important;
  background: linear-gradient(135deg, var(--kj-primary), var(--kj-primary-dark)) !important;
  color: #fff !important;
  font-size: 26rpx !important;
  font-weight: 600 !important;
  border-radius: var(--kj-radius-md) !important;
}
