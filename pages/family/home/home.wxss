.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.nav-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: var(--kj-radius-full);
  flex-shrink: 0;
}

.nav-badge--family {
  color: #be185d;
  background: #fce7f3;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.nav-status {
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.nav-status--pink {
  color: var(--kj-pink);
}

.alarm-banner {
  background: #dc2626;
  color: #fff;
  padding: 24rpx;
  border-radius: var(--kj-radius-md);
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.alarm-close {
  flex-shrink: 0;
  opacity: 0.85;
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

.stats-card {
  background: linear-gradient(135deg, #fdf2f8, #fff);
}

.stats-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #831843;
  margin-bottom: 24rpx;
  line-height: 1.3;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat-item {
  text-align: center;
  background: #fff;
  border-radius: var(--kj-radius-md);
  padding: 24rpx 12rpx;
  border: 1rpx solid #fbcfe8;
  min-height: 120rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stat-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #be185d;
  line-height: 1.2;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9d174d;
  line-height: 1.3;
}

.nudge-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 180rpx;
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.template-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.template-chip {
  font-size: 24rpx;
  color: #be185d;
  background: #fce7f3;
  padding: 12rpx 20rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
  line-height: 1.3;
}

.sent-tip {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #059669;
  font-weight: 600;
}

.article-card {
  margin-bottom: 0;
}

.article-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
}

.article-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
}

.article-tag {
  display: inline-block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--kj-pink);
  background: #fce7f3;
  padding: 6rpx 14rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
}

.device-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  font-size: 28rpx;
}

.device-item:last-child {
  border-bottom: none;
}

.device-name {
  font-weight: 600;
  color: #1e293b;
}

.device-status {
  color: #64748b;
  font-size: 26rpx;
}

/* 绑定向导 */
.bind-mask {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.96);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.bind-panel {
  width: 100%;
  max-width: 640rpx;
  color: #fff;
}

.bind-logo {
  display: block;
  text-align: center;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.bind-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.bind-sub {
  display: block;
  text-align: center;
  margin: 12rpx 0 32rpx;
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 500;
}

.bind-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: #18181b;
  border: 1rpx solid #3f3f46;
  border-radius: var(--kj-radius-md);
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.bind-tab {
  text-align: center;
  padding: 20rpx 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #71717a;
  border-radius: var(--kj-radius-sm);
  line-height: 1.3;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bind-tab--active {
  background: #3f3f46;
  color: #fff;
}

.bind-form {
  background: #18181b;
  border: 1rpx solid #3f3f46;
  border-radius: var(--kj-radius-lg);
  padding: 28rpx;
}

.bind-form-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f9a8d4;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.bind-form-title--green {
  color: #6ee7b7;
}

.bind-input {
  width: 100%;
  box-sizing: border-box;
  background: #000;
  color: #fff;
  text-align: center;
  border: 1rpx solid #52525b;
  border-radius: var(--kj-radius-sm);
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  font-family: monospace;
  margin-bottom: 16rpx;
  min-height: 88rpx;
}

.bind-hint {
  display: block;
  font-size: 24rpx;
  color: #71717a;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.qr-frame {
  width: 280rpx;
  height: 280rpx;
  margin: 20rpx auto;
  border: 2rpx dashed #10b981;
  border-radius: var(--kj-radius-lg);
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-icon,
.qr-scanning {
  font-size: 72rpx;
}

.empty-bindings {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 26rpx;
}
