/* 理疗页专用样式 — 基础布局见 styles/common.wxss */

/* 连接卡片 */
.connection-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.connection-left {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.connection-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--kj-radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.connection-icon--on { background: var(--kj-bg-indigo); }
.connection-icon--off { background: var(--kj-amber-bg); }
.connection-icon--connecting { background: var(--kj-bg-indigo); }

.connection-title {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
}

.connection-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.connection-alert {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: var(--kj-danger-bg);
  border: 1rpx solid #fecdd3;
  border-radius: var(--kj-radius-md);
  font-size: 24rpx;
  color: #be123c;
  font-weight: 600;
  line-height: 1.5;
}

/* 流程步骤 */
.flow-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.flow-step {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 600;
  flex-shrink: 0;
}

.panel-bar {
  width: 6rpx;
  height: 28rpx;
  background: var(--kj-primary);
  border-radius: var(--kj-radius-full);
  flex-shrink: 0;
}

.panel-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-picker {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.picker-value {
  font-size: 26rpx;
  color: #4338ca;
  font-weight: 600;
  line-height: 1.5;
}

.symptom-age {
  width: 100%;
  text-align: left;
}

.slider-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.slider-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #4338ca;
}

.slider-hint {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.skip-link {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 600;
  line-height: 1.5;
}

/* 匹配结果 */
.match-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.match-tag {
  font-size: 22rpx;
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  padding: 8rpx 16rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
  flex-shrink: 0;
}

.match-box {
  background: linear-gradient(180deg, #eef2ff, #f8fafc);
  border: 1rpx solid #c7d2fe;
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.match-meta {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  color: #4338ca;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.match-sim {
  background: #d1fae5;
  color: #047857;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.match-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.match-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.match-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.match-item {
  background: #f8fafc;
  border-radius: var(--kj-radius-md);
  padding: 20rpx;
  font-size: 24rpx;
  color: #64748b;
}

.match-val {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #4338ca;
}

.match-val--hot { color: #dc2626; }

.match-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

/* 在线咨询 */
.chat-card {
  display: flex;
  flex-direction: column;
  min-height: 680rpx;
}

.chat-head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
  margin-bottom: 20rpx;
}

.doctor-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.doctor-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--kj-radius-full);
  background: #eef2ff;
  color: #4338ca;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.doctor-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.doctor-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.chat-status {
  font-size: 22rpx;
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  padding: 8rpx 14rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
}

.chat-scroll {
  flex: 1;
  max-height: 400rpx;
  margin-bottom: 20rpx;
}

.chat-bubble {
  max-width: 88%;
  padding: 20rpx 24rpx;
  border-radius: var(--kj-radius-lg);
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.chat-bubble--user {
  margin-left: auto;
  background: var(--kj-primary);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.chat-bubble--doctor {
  background: var(--kj-bg-page);
  color: var(--kj-text-secondary);
  border-bottom-left-radius: 6rpx;
}

.chat-action-btn {
  display: block;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #4f46e5;
  color: #fff;
  border-radius: var(--kj-radius-sm);
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.chat-typing {
  font-size: 24rpx;
  color: #94a3b8;
  font-style: italic;
  padding: 8rpx 0;
}

.chat-quick-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.chat-q {
  padding: 20rpx 24rpx;
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  font-size: 26rpx;
  color: #3730a3;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.chat-q:last-child {
  margin-bottom: 0;
}

/* 控制面板 */
.panel-head {
  margin-bottom: 24rpx;
}

.panel-back {
  display: block;
  margin-bottom: 16rpx;
}

.panel-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.manual-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.manual-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
}

.running-box {
  background: linear-gradient(135deg, #1e1b4b, #312e81);
  border-radius: var(--kj-radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.running-tag {
  display: block;
  text-align: center;
  color: #34d399;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sim-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--kj-radius-full);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.sim-fill {
  height: 100%;
  background: linear-gradient(90deg, #34d399, #10b981);
  border-radius: var(--kj-radius-full);
  transition: width 0.3s;
}

.countdown {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.time-num {
  font-size: 56rpx;
  font-weight: 700;
  font-family: 'SF Mono', monospace;
}

.time-unit {
  font-size: 26rpx;
  color: #94a3b8;
  margin-right: 12rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: var(--kj-radius-md);
  padding: 20rpx 12rpx;
}

.metric-label {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.metric-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #a5b4fc;
}

.metric-val--hot { color: #fca5a5; }
.metric-val--vib { color: #67e8f9; }

.ready-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  padding: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 24rpx;
}

.ready-dot { color: var(--kj-primary); }

.slider-box {
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.slider-box--disabled { opacity: 0.55; }

.slider-item { margin-bottom: 28rpx; }
.slider-item:last-child { margin-bottom: 0; }

.slider-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.pill {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  padding: 6rpx 16rpx;
  border-radius: var(--kj-radius-full);
}

.pill--hot {
  color: #dc2626;
  background: #fef2f2;
}

.vibration-row { margin-top: 8rpx; }

.vibration-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.vibration-btns {
  display: flex;
  gap: 12rpx;
}

.vib-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 8rpx;
  border-radius: var(--kj-radius-md);
  border: 1rpx solid #e2e8f0;
  background: #fff;
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.vib-btn--active {
  background: var(--kj-primary);
  border-color: var(--kj-primary);
  color: #fff;
}

.start-btn {
  width: 100% !important;
  min-height: 96rpx !important;
  line-height: 96rpx !important;
  background: linear-gradient(135deg, var(--kj-primary), var(--kj-primary-dark)) !important;
  color: #fff !important;
  border-radius: 20rpx !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
}

.start-btn--stop {
  background: linear-gradient(135deg, #ef4444, #dc2626) !important;
}

/* 离线模式 */
.offline-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.offline-guide {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-tag {
  align-self: flex-start;
  font-size: 24rpx;
  font-weight: 600;
  color: #92400e;
  background: #fef3c7;
  padding: 10rpx 18rpx;
  border-radius: var(--kj-radius-sm);
}

.guide-text {
  font-size: 26rpx;
  color: #78350f;
  line-height: 1.7;
}

.video-card {
  background: #0f172a;
  color: #fff;
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.video-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.video-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--kj-radius-md);
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.video-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
  line-height: 1.4;
}

.video-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.live-tag {
  font-size: 22rpx;
  color: #34d399;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.1);
  padding: 10rpx 14rpx;
  border-radius: var(--kj-radius-sm);
  flex-shrink: 0;
}

.article-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.article-item:last-child { border-bottom: none; }

.article-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.4;
}

.article-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

/* 冷启动 */
.coldboot-mask {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.96);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.coldboot-panel {
  width: 100%;
  max-height: 88vh;
  overflow-y: auto;
  color: #fff;
}

.coldboot-logo {
  display: block;
  text-align: center;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.coldboot-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.coldboot-sub {
  display: block;
  text-align: center;
  margin: 12rpx 0 32rpx;
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 600;
}

.coldboot-label {
  display: block;
  font-size: 26rpx;
  color: #a1a1aa;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.coldboot-option {
  border-radius: var(--kj-radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.coldboot-option--indigo {
  background: linear-gradient(135deg, #312e81, rgba(49, 46, 129, 0.8));
  border: 1rpx solid rgba(99, 102, 241, 0.4);
}

.coldboot-option--emerald {
  background: linear-gradient(135deg, #064e3b, #18181b);
  border: 1rpx solid rgba(16, 185, 129, 0.4);
}

.option-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.option-title {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.coldboot-option--indigo .option-title { color: #c7d2fe; }
.coldboot-option--emerald .option-title { color: #6ee7b7; }

.option-tag {
  font-size: 20rpx;
  background: rgba(99, 102, 241, 0.5);
  color: #e0e7ff;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.option-tag--emerald {
  background: rgba(16, 185, 129, 0.5);
  color: #a7f3d0;
}

.option-desc {
  font-size: 26rpx;
  color: #d4d4d8;
  line-height: 1.7;
}

.coldboot-form {
  background: #18181b;
  border: 1rpx solid #3f3f46;
  border-radius: var(--kj-radius-xl);
  padding: 28rpx;
}

.form-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 700;
  flex: 1;
}

.form-title--indigo { color: #c7d2fe; }
.form-title--emerald { color: #6ee7b7; }

.form-back {
  font-size: 24rpx;
  color: #a1a1aa;
  text-decoration: underline;
  flex-shrink: 0;
}

.code-input {
  width: 100%;
  box-sizing: border-box;
  background: #000;
  color: #fff;
  text-align: center;
  border: 1rpx solid #52525b;
  border-radius: var(--kj-radius-md);
  padding: 28rpx;
  font-size: 36rpx;
  font-weight: 700;
  font-family: monospace;
  margin-bottom: 20rpx;
  min-height: 96rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #a1a1aa;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(0, 0, 0, 0.4);
  border: 1rpx solid #3f3f46;
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.age-input {
  width: 120rpx;
  text-align: center;
  background: #000;
  color: #fff;
  border: 1rpx solid #52525b;
  border-radius: var(--kj-radius-sm);
  padding: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.picker-row {
  background: rgba(0, 0, 0, 0.4);
  border: 1rpx solid #3f3f46;
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #e4e4e7;
  line-height: 1.5;
}

.connecting-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 998;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.connecting-box {
  background: var(--kj-bg-card);
  border-radius: var(--kj-radius-xl);
  padding: 48rpx 40rpx;
  text-align: center;
  width: 85%;
  max-width: 560rpx;
  box-shadow: var(--kj-shadow);
}

.connecting-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.connecting-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.connecting-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
}
