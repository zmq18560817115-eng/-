<view class="page page--tab">
  <!-- 工具条：消息 + 切换账号 -->
  <view class="sub-toolbar">
    <view class="toolbar-left">
      <view class="icon-btn" bindtap="onOpenMessages">
        <text>🔔</text>
        <view wx:if="{{messageUnread > 0}}" class="icon-btn-badge">{{messageUnread > 9 ? '9+' : messageUnread}}</view>
      </view>
      <text class="status-dot">● 服务在线</text>
    </view>
    <text class="link-text" bindtap="onSwitchAccount">切换账号</text>
  </view>

  <!-- 连接状态卡片 -->
  <view class="card connection-card">
    <view class="connection-row">
      <view class="connection-left">
        <view class="connection-icon {{isConnecting ? 'connection-icon--connecting' : (isLinked ? 'connection-icon--on' : 'connection-icon--off')}}">{{isConnecting ? '⏳' : '📡'}}</view>
        <view class="connection-text">
          <view class="connection-title">
            <text>理疗仪连接状态：</text>
            <text class="badge {{isLinked ? 'badge--on' : (isConnecting ? 'badge--connecting' : 'badge--off')}}">{{statusBadge}}</text>
          </view>
          <text class="connection-desc">{{connectionDesc}}</text>
        </view>
      </view>
      <switch checked="{{isLinked}}" color="#4f46e5" disabled="{{isConnecting}}" bindchange="onToggleConnection" />
    </view>
    <view wx:if="{{connectionError}}" class="connection-alert">⚠️ 安全提醒：{{connectionError}}</view>
  </view>

  <!-- STEP 1: 症状自评 -->
  <view wx:if="{{isLinked && therapyStep === 'symptom'}}" class="card flow-card">
    <view class="flow-head">
      <view class="section-title-row">
        <view class="panel-bar"></view>
        <text class="section-title">自评：当前膝盖感受</text>
      </view>
      <text class="flow-step">1 / 2</text>
    </view>
    <view class="form-block symptom-row">
      <text class="form-block-label">您今年多大年龄了？</text>
      <input class="form-input symptom-age" type="number" placeholder="请输入年龄" value="{{symptomAge}}" bindinput="onSymptomAgeInput" />
    </view>
    <picker mode="selector" range="{{wearLabels}}" value="{{symptomWearIdx}}" bindchange="onSymptomWearChange">
      <view class="form-block form-picker">
        <text class="form-block-label">膝关节磨损程度</text>
        <text class="picker-value">{{wearLabels[symptomWearIdx]}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{fluidLabels}}" value="{{symptomFluidIdx}}" bindchange="onSymptomFluidChange">
      <view class="form-block form-picker">
        <text class="form-block-label">关节积液肿胀感</text>
        <text class="picker-value">{{fluidLabels[symptomFluidIdx]}}</text>
      </view>
    </picker>
    <view class="form-block">
      <view class="slider-label-row">
        <text class="form-block-label">疼痛评分</text>
        <text class="slider-value">{{symptomPainScore}} 分</text>
      </view>
      <slider min="1" max="10" value="{{symptomPainScore}}" activeColor="#6366f1" block-size="24" bindchange="onSymptomPainChange" />
      <view class="slider-hint"><text>1分 轻微</text><text>10分 剧烈</text></view>
    </view>
    <button class="btn-indigo" bindtap="onRunMatch">生成智能评估方案</button>
    <text class="skip-link" bindtap="onSkipToControl">已有治疗方案，直接进入控制面板</text>
  </view>

  <!-- STEP 2: 方案匹配审阅 -->
  <view wx:if="{{isLinked && therapyStep === 'matching' && matchResult}}" class="card flow-card">
    <view class="match-head">
      <text class="link-back" bindtap="onGoSymptom">← 返回修改症状</text>
      <text class="match-tag">匹配成功</text>
    </view>
    <view class="match-box">
      <view class="match-meta">
        <text>🏅 完美匹配三甲临床专家相似案列</text>
        <text class="match-sim">相似度 {{matchResult.similarity}}%</text>
      </view>
      <text class="match-name">{{matchResult.case_name}}</text>
      <text class="match-desc">根据欧氏距离聚类诊断，该方案由博爱医院膝病研委会审定。</text>
    </view>
    <view class="match-grid">
      <view class="match-item"><text>左拉力</text><text class="match-val">{{matchResult.left_force}}N</text></view>
      <view class="match-item"><text>右拉力</text><text class="match-val">{{matchResult.right_force}}N</text></view>
      <view class="match-item"><text>热敷</text><text class="match-val match-val--hot">{{matchResult.temp}}℃</text></view>
      <view class="match-item"><text>时长</text><text class="match-val">{{matchResult.duration}}分</text></view>
    </view>
    <button class="btn-indigo" bindtap="onAcceptMatch">接受并载入 AI 推荐方案</button>
    <view class="match-actions">
      <button class="btn-outline" bindtap="onGoSymptom">修改症状</button>
      <button class="btn-outline btn-outline--green" bindtap="onGoChat">咨询在线医生</button>
    </view>
  </view>

  <!-- STEP 3: 在线医生咨询 -->
  <view wx:if="{{isLinked && therapyStep === 'chat'}}" class="card chat-card">
    <view class="chat-head">
      <text class="link-back" bindtap="onGoMatching">← 返回上一步</text>
      <view class="doctor-info">
        <text class="doctor-avatar">李</text>
        <view><text class="doctor-name">李敬东 主任医师</text><text class="doctor-sub">三甲博爱关节医学在线支持</text></view>
      </view>
      <text class="chat-status">临床会诊中</text>
    </view>
    <scroll-view scroll-y class="chat-scroll" scroll-into-view="{{chatScrollId}}">
      <view wx:for="{{chatMessages}}" wx:key="index" class="chat-bubble chat-bubble--{{item.sender}}" id="msg-{{index}}">
        <text>{{item.text}}</text>
        <text wx:if="{{item.isAction && item.actionParams}}" class="chat-action-btn" data-idx="{{index}}" bindtap="onApplyChatRx">一键应用特配方案</text>
      </view>
      <view wx:if="{{isDoctorTyping}}" class="chat-typing">李主任正在输入…</view>
    </scroll-view>
    <view class="chat-quick">
      <text class="chat-quick-label">针对自检结果，您可以直接追问：</text>
      <view class="chat-q" data-type="1" bindtap="onChatQuestion">❓ 疼痛感较高，拉力会拉伤韧带吗？</view>
      <view class="chat-q" data-type="2" bindtap="onChatQuestion">❓ 积液发胀期，如何安全热敷？</view>
      <view class="chat-q" data-type="3" bindtap="onChatQuestion">❓ 慢磨损退行性，可以用弱压防护吗？</view>
    </view>
  </view>

  <!-- STEP 4: 理疗控制面板 -->
  <view wx:if="{{isLinked && therapyStep === 'control'}}" class="card panel-card">
    <view class="panel-head">
      <text class="link-back panel-back" bindtap="onGoSymptom">← 返回重新自评</text>
      <view class="panel-head-row">
        <view class="panel-title-row">
          <view class="panel-bar"></view>
          <text class="section-title">理疗控制面板</text>
        </view>
        <view class="manual-row">
          <text class="manual-label">解锁微调</text>
          <switch checked="{{manualMode}}" color="#6366f1" disabled="{{isRunning}}" bindchange="onToggleManual" />
        </view>
      </view>
    </view>

    <view wx:if="{{isRunning}}" class="running-box">
      <text class="running-tag">● 理疗仪运行中 (ACTIVE)</text>
      <view class="sim-bar"><view class="sim-fill" style="width: {{simProgress}}%;"></view></view>
      <view class="countdown">
        <text class="time-num">{{timeMin}}</text><text class="time-unit">分</text>
        <text class="time-num">{{timeSec}}</text><text class="time-unit">秒</text>
      </view>
      <view class="metric-grid">
        <view class="metric"><text class="metric-label">左侧拉力</text><text class="metric-val">{{leftForce}}N</text></view>
        <view class="metric"><text class="metric-label">右侧拉力</text><text class="metric-val">{{rightForce}}N</text></view>
        <view class="metric"><text class="metric-label">红外热敷</text><text class="metric-val metric-val--hot">{{temp}}℃</text></view>
        <view class="metric"><text class="metric-label">温和按摩</text><text class="metric-val metric-val--vib">{{vibrationLabel}}</text></view>
      </view>
    </view>
    <view wx:else class="ready-box">
      <text class="ready-dot">●</text>
      <text>理疗仪已就绪，请启动康复理疗</text>
    </view>

    <view class="slider-box {{(!manualMode || isRunning) ? 'slider-box--disabled' : ''}}">
      <view class="slider-item">
        <view class="slider-head"><text>左侧牵引拉力</text><text class="pill">{{leftForce}} N</text></view>
        <slider min="10" max="40" value="{{leftForce}}" activeColor="#4f46e5" block-size="18" disabled="{{!manualMode || isRunning}}" bindchange="onLeftForceChange" />
      </view>
      <view class="slider-item">
        <view class="slider-head"><text>右侧牵引拉力</text><text class="pill">{{rightForce}} N</text></view>
        <slider min="10" max="40" value="{{rightForce}}" activeColor="#4f46e5" block-size="18" disabled="{{!manualMode || isRunning}}" bindchange="onRightForceChange" />
      </view>
      <view class="slider-item">
        <view class="slider-head"><text>红外热敷温度</text><text class="pill pill--hot">{{temp}} ℃</text></view>
        <slider min="35" max="50" value="{{temp}}" activeColor="#ef4444" block-size="18" disabled="{{!manualMode || isRunning}}" bindchange="onTempChange" />
      </view>
      <view class="slider-item">
        <view class="slider-head"><text>定时理疗时间</text><text class="pill">{{duration}} 分钟</text></view>
        <slider min="5" max="45" value="{{duration}}" activeColor="#4f46e5" block-size="18" disabled="{{!manualMode || isRunning}}" bindchange="onDurationChange" />
      </view>

      <view class="vibration-row">
        <text class="vibration-label">按摩振动模式</text>
        <view class="vibration-btns">
          <view class="vib-btn {{vibration === 0 ? 'vib-btn--active' : ''}}" data-mode="0" bindtap="onVibrationChange">无振动</view>
          <view class="vib-btn {{vibration === 1 ? 'vib-btn--active' : ''}}" data-mode="1" bindtap="onVibrationChange">低频揉和</view>
          <view class="vib-btn {{vibration === 2 ? 'vib-btn--active' : ''}}" data-mode="2" bindtap="onVibrationChange">高频舒张</view>
        </view>
      </view>
    </view>

    <button class="start-btn {{isRunning ? 'start-btn--stop' : ''}}" bindtap="onToggleRunning">
      {{isRunning ? '■ 结束治疗 (紧急停机卸压)' : '▶ 开始物理康复治疗'}}
    </button>
  </view>

  <view wx:else class="offline-stack">
    <!-- 居家自练保健指南 -->
    <view class="gradient-amber offline-guide">
      <text class="guide-tag">💡 居家自练保健指南</text>
      <text class="guide-text">目前连接不到您的理疗仪，已经自动为您开启【居家徒手康复课程】。您可以在床上或沙发上跟着下面的视频练习膝盖理疗操，完成后点击打卡，成果也会同步至家属端。</text>

      <view class="video-card">
        <view class="video-left">
          <text class="video-icon">🧍</text>
          <view>
            <text class="video-title">第1套：居家股四头肌徒手牵引操</text>
            <text class="video-sub">顺畅呼吸，跟随视频动作做拉伸 · 正在播放</text>
          </view>
        </view>
        <text class="live-tag">● 进行中</text>
      </view>

        <button class="btn-amber" bindtap="onOfflineCheckIn">完成跟练，一键打卡</button>
    </view>

    <!-- 适老居家健康理疗操推荐 -->
    <view class="card">
      <view class="section-head">
        <view class="section-title-row">
          <text class="section-icon">⛰️</text>
          <text class="section-title">适老居家健康理疗操推荐</text>
        </view>
        <text class="pill-tag pill-tag--amber">全年龄段免费安全</text>
      </view>

      <view class="exercise-item">
        <view class="exercise-left">
          <view class="exercise-icon">⛰️</view>
          <view>
            <text class="exercise-name">第2套：靠墙静蹲稳固髌骨法</text>
            <text class="exercise-desc">适合感觉膝盖发软、走路没劲的康复人群</text>
          </view>
        </view>
        <button class="btn-outline mini-btn" data-course="2" bindtap="onSelectCourse">去自练</button>
      </view>

      <view class="exercise-item">
        <view class="exercise-left">
          <view class="exercise-icon">👣</view>
          <view>
            <text class="exercise-name">第3套：卧姿踝泵膝部消肿操</text>
            <text class="exercise-desc">专门针对晨起膝盖僵硬发胀、下不来床</text>
          </view>
        </view>
        <button class="btn-outline mini-btn" data-course="3" bindtap="onSelectCourse">去自练</button>
      </view>
    </view>

    <!-- 膝部健康科普 -->
    <view class="card">
      <view class="section-title-row" style="margin-bottom: 16rpx;">
        <text class="section-icon">📖</text>
        <text class="section-title">膝部健康科普专栏</text>
      </view>
      <view class="article-item">
        <text class="article-title">为什么老年人晨起膝盖会「发僵」？</text>
        <text class="article-desc">滑膜液夜间回流减少，适度热敷与踝泵操可快速缓解。</text>
      </view>
      <view class="article-item">
        <text class="article-title">牵引拉伸会不会拉伤韧带？</text>
        <text class="article-desc">膝悦智能过载保护阀会在超过设定拉力时自动泄压。</text>
      </view>
    </view>
  </view>

  <!-- 连接中遮罩 -->
  <view wx:if="{{isConnecting}}" class="connecting-mask">
    <view class="connecting-box">
      <text class="connecting-icon">📡</text>
      <text class="connecting-title">正在搜索并配对膝悦理疗仪</text>
      <text class="connecting-sub">请保持设备开机并靠近手机…</text>
    </view>
  </view>

  <!-- 冷启动引导 -->
  <view wx:if="{{showColdBoot}}" class="coldboot-mask">
    <view class="coldboot-panel">
      <text class="coldboot-logo">🦵</text>
      <text class="coldboot-title">欢迎使用「膝悦 (KneeJoy)」</text>
      <text class="coldboot-sub">—— 您的专属居家膝关节理疗仪 ——</text>

      <view wx:if="{{coldBootStep === 'select'}}" class="coldboot-body">
        <text class="coldboot-label">请选择您的开始方式：</text>
        <view class="coldboot-option coldboot-option--indigo" data-step="doctor" bindtap="onColdBootNav">
          <view class="option-head">
            <text class="option-title">方式一：医生方案 一键导入</text>
            <text class="option-tag">适合已有处方</text>
          </view>
          <text class="option-desc">如果您手里有医生给的 6 位数字授权码，输入后可以一键载入医生配好的牵引拉伸方案。</text>
        </view>
        <view class="coldboot-option coldboot-option--emerald" data-step="assessment" bindtap="onColdBootNav">
          <view class="option-head">
            <text class="option-title">方式二：智能助理 帮我推荐</text>
            <text class="option-tag option-tag--emerald">适合居家理疗</text>
          </view>
          <text class="option-desc">只需简单填报您的年龄和膝盖状况，智能助理会自动推荐适合您的起步拉伸方案。</text>
        </view>
      </view>

      <view wx:if="{{coldBootStep === 'doctor'}}" class="coldboot-form">
        <view class="form-head">
          <text class="form-title form-title--indigo">请输入医生给您的 6 位验证码</text>
          <text class="form-back" data-step="select" bindtap="onColdBootNav">返回切换</text>
        </view>
        <input class="code-input" maxlength="10" placeholder="请输入授权码" value="{{doctorCode}}" bindinput="onDoctorCodeInput" />
        <text class="form-hint">💡 输入并确认后，系统会自动载入主治专家为您配置的定制理疗处方。</text>
        <button class="btn-indigo" bindtap="onSubmitDoctorCode">确认导入医生方案</button>
      </view>

      <view wx:if="{{coldBootStep === 'assessment'}}" class="coldboot-form">
        <view class="form-head">
          <text class="form-title form-title--emerald">填报您目前的症状</text>
          <text class="form-back" data-step="select" bindtap="onColdBootNav">返回切换</text>
        </view>
        <view class="form-row">
          <text>您的年龄</text>
          <input class="age-input" type="number" placeholder="岁" value="{{assessAge}}" bindinput="onAssessAgeInput" />
        </view>
        <picker mode="selector" range="{{wearLabels}}" value="{{assessWearIdx}}" bindchange="onAssessWearChange">
          <view class="picker-row">膝关节磨损：{{wearLabels[assessWearIdx]}}</view>
        </picker>
        <picker mode="selector" range="{{fluidLabels}}" value="{{assessFluidIdx}}" bindchange="onAssessFluidChange">
          <view class="picker-row">关节积液感：{{fluidLabels[assessFluidIdx]}}</view>
        </picker>
        <picker mode="selector" range="{{painLabels}}" value="{{assessPainIdx}}" bindchange="onAssessPainChange">
          <view class="picker-row">疼痛评分：{{painLabels[assessPainIdx]}}</view>
        </picker>
        <button class="btn-indigo" bindtap="onSubmitAssessment">获取 AI 智能推荐方案</button>
      </view>
    </view>
  </view>
</view>
