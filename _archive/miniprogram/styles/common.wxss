/* ========== 膝悦小程序设计规范 v2 ========== */

/* 页面容器 */
.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 32rpx;
  box-sizing: border-box;
  background: var(--kj-bg-page);
}

.page--tab {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.page-with-tabbar {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: var(--kj-bg-page);
}

/* 卡片 — 主模块统一 xl 圆角 */
.card {
  background: var(--kj-bg-card);
  border-radius: var(--kj-radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--kj-border-soft);
  box-shadow: var(--kj-shadow);
}

.card:last-child {
  margin-bottom: 0;
}

/* 内嵌区块 — 统一 md 圆角 */
.surface {
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
}

.surface--indigo {
  background: linear-gradient(180deg, var(--kj-bg-indigo), var(--kj-bg-muted));
  border-color: var(--kj-primary-border);
}

/* typography */
.text-caption {
  font-size: 22rpx;
  color: var(--kj-text-caption);
  line-height: 1.5;
}

.text-body {
  font-size: 28rpx;
  color: var(--kj-text-secondary);
  line-height: 1.6;
}

.text-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--kj-text);
  line-height: 1.4;
}

.text-subtitle {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--kj-text-muted);
  line-height: 1.5;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--kj-text);
  line-height: 1.4;
}

.section-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.section-icon {
  font-size: 32rpx;
  line-height: 1;
}

.panel-bar {
  width: 6rpx;
  height: 28rpx;
  background: var(--kj-primary);
  border-radius: var(--kj-radius-full);
  flex-shrink: 0;
}

/* 标签 */
.badge {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--kj-radius-xs);
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
}

.badge--on,
.badge--connecting {
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  border: 1rpx solid var(--kj-primary-border);
}

.badge--off {
  color: var(--kj-amber);
  background: var(--kj-amber-bg);
  border: 1rpx solid #fde68a;
}

.pill-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--kj-radius-full);
  font-weight: 600;
  white-space: nowrap;
}

.pill-tag--emerald {
  color: #047857;
  background: #d1fae5;
  border: 1rpx solid #a7f3d0;
}

.pill-tag--indigo {
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  border: 1rpx solid var(--kj-primary-border);
}

.pill-tag--amber {
  color: var(--kj-amber);
  background: #fef3c7;
  border: 1rpx solid #fde68a;
}

.pill {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--kj-primary-text);
  background: var(--kj-bg-indigo);
  padding: 6rpx 16rpx;
  border-radius: var(--kj-radius-full);
}

.pill--hot {
  color: var(--kj-danger);
  background: var(--kj-danger-bg);
}

/* 按钮 — 统一 lg 圆角 + 88rpx 触控高度 */
.btn-indigo,
.btn-amber,
.btn-pink,
.btn-primary {
  width: 100% !important;
  min-height: 88rpx !important;
  line-height: 88rpx !important;
  padding: 0 32rpx !important;
  border-radius: var(--kj-radius-lg) !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  box-sizing: border-box !important;
}

.btn-indigo,
.btn-primary {
  background: linear-gradient(135deg, var(--kj-primary), var(--kj-primary-dark)) !important;
  color: #ffffff !important;
}

.btn-amber {
  background: linear-gradient(135deg, #f59e0b, #d97706) !important;
  color: #ffffff !important;
}

.btn-pink {
  background: linear-gradient(135deg, #ec4899, var(--kj-pink)) !important;
  color: #ffffff !important;
}

.btn-outline {
  min-height: 80rpx !important;
  line-height: 80rpx !important;
  padding: 0 24rpx !important;
  border-radius: var(--kj-radius-lg) !important;
  font-size: 26rpx !important;
  font-weight: 600 !important;
  background: var(--kj-bg-card) !important;
  color: var(--kj-text-muted) !important;
  border: 1rpx solid var(--kj-border) !important;
  box-sizing: border-box !important;
}

.btn-outline--green {
  color: #047857 !important;
  border-color: #a7f3d0 !important;
  background: var(--kj-success-bg) !important;
}

.link-back,
.link-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--kj-primary);
  line-height: 1.4;
}

.link-text--muted {
  color: var(--kj-text-muted);
}

/* 表单 */
.form-block {
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-block-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--kj-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  background: var(--kj-bg-card);
  border: 1rpx solid var(--kj-border);
  border-radius: var(--kj-radius-sm);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--kj-text);
  min-height: 80rpx;
  box-sizing: border-box;
}

/* 顶栏工具条 */
.sub-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.toolbar-left,
.toolbar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--kj-radius-lg);
  background: var(--kj-bg-indigo);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.icon-btn-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: var(--kj-danger);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: var(--kj-radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.status-dot {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--kj-success);
  white-space: nowrap;
}

/* 列表项 */
.exercise-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--kj-bg-muted);
  border: 1rpx solid var(--kj-bg-page);
  border-radius: var(--kj-radius-md);
  margin-bottom: 16rpx;
}

.exercise-item:last-child {
  margin-bottom: 0;
}

.exercise-left {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.exercise-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--kj-radius-md);
  background: var(--kj-amber-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.exercise-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--kj-text-secondary);
  line-height: 1.4;
}

.exercise-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--kj-text-muted);
  line-height: 1.5;
}

.mini-btn {
  flex-shrink: 0;
  min-width: 140rpx !important;
  width: auto !important;
  padding: 0 24rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  font-size: 26rpx !important;
  border-radius: var(--kj-radius-lg) !important;
}

.gradient-amber {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), var(--kj-amber-bg));
  border: 1rpx solid #fde68a;
  border-radius: var(--kj-radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* 筛选 Tab 通用 */
.filter-tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 12rpx;
  border-radius: var(--kj-radius-md);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--kj-text-muted);
  background: var(--kj-bg-card);
  border: 1rpx solid var(--kj-border);
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.filter-tab--active {
  background: var(--kj-primary);
  border-color: var(--kj-primary);
  color: #fff;
}

/* 底部 Tab（医生/家属） */
.mini-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: var(--kj-bg-card);
  border-top: 1rpx solid var(--kj-border);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.05);
}

.mini-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 10rpx;
  font-size: 22rpx;
  color: var(--kj-text-muted);
  font-weight: 600;
  min-height: 100rpx;
  box-sizing: border-box;
}

.mini-tab--active {
  color: var(--kj-primary-dark);
}

.mini-tab--pink.mini-tab--active {
  color: var(--kj-pink);
}

.mini-tab-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
  line-height: 1;
}

.logout-btn {
  width: 100% !important;
  min-height: 88rpx !important;
  line-height: 88rpx !important;
  margin-top: 8rpx !important;
  background: var(--kj-bg-page) !important;
  color: var(--kj-text-muted) !important;
  border: 1rpx solid var(--kj-border) !important;
  border-radius: var(--kj-radius-lg) !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
}

.logout-tip {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  padding-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--kj-text-caption);
  line-height: 1.6;
}

/* 弹层 */
.modal-box {
  background: var(--kj-bg-card);
  border-radius: var(--kj-radius-xl);
  padding: 48rpx 40rpx;
  text-align: center;
  width: 85%;
  max-width: 560rpx;
  box-shadow: var(--kj-shadow);
}
